{
  "version": 4,
  "event_types": {
    "cell-message": {
      "side_effects": ["notify_assignee", "notify_tmux_if_urgent"],
      "description": "Direct message between agents. MCP handles inbox write + tmux delivery; bus is trace-only."
    },
    "announcement": {
      "side_effects": ["notify_assignee", "notify_tmux_if_urgent"],
      "description": "Broadcast-style message to agent or group."
    },
    "worker.started": {
      "side_effects": ["notify_assignee"],
      "description": "Worker agent launched and registered."
    },
    "worker.commit": {
      "side_effects": ["notify_chief_of_staff"],
      "description": "Worker made a git commit."
    },
    "worker.loop": {
      "side_effects": [],
      "description": "Worker completed one loop iteration."
    },
    "worker.transition": {
      "side_effects": ["notify_assignee", "notify_tmux_if_urgent"],
      "description": "Worker changed lifecycle type."
    },
    "worker.regression": {
      "side_effects": ["notify_assignee", "notify_tmux_if_urgent"],
      "description": "Monitoring worker detected a regression."
    },
    "task.started": {
      "side_effects": ["update_tasks_json"],
      "description": "Worker started an assigned task."
    },
    "task.completed": {
      "side_effects": ["update_tasks_json", "notify_assignee"],
      "description": "Worker completed an assigned task."
    },
    "prompt": {
      "side_effects": [],
      "description": "User prompt event (trace only)."
    },
    "file-edit": {
      "side_effects": [],
      "description": "File was edited by an agent."
    },
    "tool-call": {
      "side_effects": [],
      "description": "Tool was invoked by an agent."
    },
    "deploy": {
      "side_effects": ["notify_human_agent"],
      "description": "Deployment event."
    },
    "error": {
      "side_effects": ["dlq_if_critical"],
      "description": "Error event from agent."
    },
    "config-change": {
      "side_effects": ["notify_human_agent"],
      "description": "Configuration file was changed."
    },
    "session.start": {
      "side_effects": [],
      "description": "Agent session started."
    },
    "session.end": {
      "side_effects": [],
      "description": "Agent session ended."
    },
    "agent.stopped": {
      "side_effects": [],
      "description": "Agent stopped gracefully."
    },
    "agent.respawned": {
      "side_effects": ["notify_tmux_if_urgent"],
      "description": "Watchdog respawned agent after sleep window elapsed."
    },
    "agent.crash": {
      "side_effects": ["notify_assignee"],
      "description": "Pane or process died without graceful-stop sentinel."
    },
    "agent.stuck": {
      "side_effects": ["notify_assignee"],
      "description": "Agent process alive but no tool calls for >10 min."
    },
    "agent.nudged": {
      "side_effects": [],
      "description": "Watchdog sent a wake prompt to a stuck agent."
    },
    "agent.crash-loop": {
      "side_effects": ["notify_assignee", "notify_tmux_if_urgent"],
      "description": ">3 crashes per hour — watchdog stopped retrying."
    },
    "agent.state-changed": {
      "side_effects": [],
      "description": "Observability trace for state mutations."
    },
    "agent.memory-updated": {
      "side_effects": [],
      "description": "Observability trace for MEMORY.md edits."
    },
    "agent.policy-appended": {
      "side_effects": [],
      "description": "Audit trail for policy context injections."
    },
    "agent.issue-filed": {
      "side_effects": ["notify_human_agent"],
      "description": "Agent filed a GitHub issue."
    },
    "notification": {
      "side_effects": ["notify_human_agent"],
      "description": "Operator notification. Side-effect calls terminal-notifier."
    }
  },
  "filters": {
    "messages": "cell-message|worker\\.|announcement",
    "telemetry": "file-edit|tool-call|deploy|error|prompt|config-change",
    "workers": "worker\\.",
    "lifecycle": "session\\.",
    "tasks": "task\\.",
    "agent-state": "agent\\.state-changed|agent\\.memory-updated|agent\\.policy-appended|agent\\.issue-filed"
  }
}
