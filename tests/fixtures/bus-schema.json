{
  "version": 3,
  "event_types": {
    "worker.merge-request": {
      "description": "Worker signals it has commits ready to merge into main",
      "side_effects": ["notify_chief_of_staff", "materialize_worker_outbox"]
    },
    "worker.merged": {
      "description": "Chief-of-staff merged a worker branch into main",
      "side_effects": ["auto_rebase_workers"]
    },
    "worker.message": {
      "description": "Direct message between workers",
      "side_effects": ["deliver_tmux", "notify_tmux_if_urgent"]
    },
    "worker.task-update": {
      "description": "Worker updated a task status",
      "side_effects": ["update_tasks_json", "notify_assignee"]
    },
    "worker.started": {
      "description": "Worker agent launched and registered.",
      "side_effects": ["notify_assignee"]
    },
    "worker.commit": {
      "description": "Worker made a git commit.",
      "side_effects": ["notify_chief_of_staff"]
    },
    "worker.loop": {
      "description": "Worker completed one loop iteration.",
      "side_effects": []
    },
    "worker.transition": {
      "description": "Worker changed lifecycle type.",
      "side_effects": ["notify_assignee", "notify_tmux_if_urgent"]
    },
    "worker.regression": {
      "description": "Monitoring worker detected a regression.",
      "side_effects": ["notify_assignee", "notify_tmux_if_urgent"]
    },
    "prompt": {
      "description": "User prompt event.",
      "side_effects": ["sync_harness_inbox"]
    },
    "tool-call": {
      "description": "Tool was invoked by an agent.",
      "side_effects": []
    },
    "file-edit": {
      "description": "File was edited by an agent.",
      "side_effects": []
    },
    "error": {
      "description": "Error event from agent.",
      "side_effects": ["dlq_if_critical"]
    },
    "deploy": {
      "description": "Deployment event.",
      "side_effects": ["notify_human_agent"]
    },
    "config-change": {
      "description": "Configuration file was changed.",
      "side_effects": ["notify_human_agent"]
    },
    "session.start": {
      "description": "Agent session started.",
      "side_effects": []
    },
    "session.end": {
      "description": "Agent session ended.",
      "side_effects": []
    },
    "announcement": {
      "description": "Broadcast-style message to agent or group.",
      "side_effects": ["notify_assignee", "notify_tmux_if_urgent", "append_outbox"]
    },
    "task.started": {
      "description": "Worker started an assigned task.",
      "side_effects": ["update_tasks_json"]
    },
    "task.completed": {
      "description": "Worker completed an assigned task.",
      "side_effects": ["update_tasks_json", "notify_assignee"]
    },
    "notification": {
      "description": "Operator notification request.",
      "side_effects": ["notify_human_agent"]
    }
  },
  "filters": {
    "messages": "worker\\.message|announcement",
    "telemetry": "file-edit|tool-call|deploy|error|prompt|config-change",
    "workers": "worker\\.",
    "lifecycle": "session\\.",
    "tasks": "task\\."
  }
}
