{
  "_comment": "Canonical hook registry. setup-hooks.sh reads this to install into ~/.claude/settings.json. lint-hooks.sh reads this to verify installation.",
  "hooks": [
    {
      "id": "worker-session-register",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/hooks/publishers/worker-session-register.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Registers worker's tmux pane and session in fleet registry on each prompt"
    },
    {
      "id": "snippet-injector",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/plugins/claude-context-orchestrator/scripts/snippets/snippet_injector.py",
      "runner": "python3",
      "matcher": ".*",
      "required": false,
      "category": "plugin",
      "description": "[INJECT] Injects contextual snippets into prompts based on keyword matching"
    },
    {
      "id": "prompt-publisher",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/hooks/publishers/prompt-publisher.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Emits prompt events to event bus for watchdog liveness and coordinator inbox routing"
    },
    {
      "id": "prompt-echo-deferred",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/hooks/publishers/prompt-echo-deferred.sh",
      "required": false,
      "category": "user",
      "description": "[INJECT] Deferred echo chain — feeds queued follow-up prompts from stop-echo.sh back into the session"
    },
    {
      "id": "pii-firewall",
      "event": "PreToolUse",
      "path": "{PROJECT_ROOT}/.claude/hooks/pii-firewall.sh",
      "required": false,
      "category": "project",
      "description": "[GATE] Blocks direct access to customer conversation content for PIPL compliance. Requires qwen-analyst MCP for data analysis"
    },
    {
      "id": "tool-policy-gate",
      "event": "PreToolUse",
      "path": "~/.claude-fleet/hooks/gates/tool-policy-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Enforces per-worker tool deny-list from permissions.json. Blocks matching tool calls with explanation"
    },
    {
      "id": "git-safety-gate",
      "event": "PreToolUse",
      "path": "~/.claude-fleet/hooks/gates/git-safety-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks dangerous git operations: --amend (use new commits), branch names not matching worker/*, direct prod SSH"
    },
    {
      "id": "pre-tool-context-injector",
      "event": "PreToolUse",
      "path": "~/.claude-fleet/hooks/interceptors/pre-tool-context-injector.sh",
      "required": true,
      "category": "core",
      "description": "[INJECT] Injects policy hints, inbox scan, phase context, and subagent agent_id before each tool call"
    },
    {
      "id": "liveness-heartbeat-post",
      "event": "PostToolUse",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp after each tool call — watchdog uses this for stuck detection (>10min = stuck)"
    },
    {
      "id": "liveness-heartbeat-prompt",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on prompt submit — watchdog uses this for stuck detection (>10min = stuck)"
    },
    {
      "id": "subagent-start",
      "event": "SubagentStart",
      "path": "~/.claude-fleet/hooks/publishers/subagent-lifecycle.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Tracks subagent spawn for resource management and auto-completion of agent-scoped hooks"
    },
    {
      "id": "subagent-stop",
      "event": "SubagentStop",
      "path": "~/.claude-fleet/hooks/publishers/subagent-lifecycle.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Tracks subagent exit — auto-completes dynamic hooks scoped to this agent_id"
    },
    {
      "id": "pre-compact",
      "event": "PreCompact",
      "path": "~/.claude-fleet/scripts/pre-compact.sh",
      "timeout": 5000,
      "required": true,
      "category": "core",
      "description": "[INJECT] Re-injects seed template, worker state, and task queue before context compaction to prevent amnesia"
    },
    {
      "id": "liveness-heartbeat-stop",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on session stop — signals clean exit to watchdog"
    },
    {
      "id": "stop-worker-dispatch",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/gates/stop-worker-dispatch.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if worker has in-progress tasks. Ensures work is completed or handed off before stopping"
    },
    {
      "id": "stop-inbox-drain",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/gates/stop-inbox-drain.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if unread BMS messages or pending ACKs exist. Ensures inbox is drained before stopping"
    },
    {
      "id": "stop-echo",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/publishers/stop-echo.sh",
      "required": false,
      "category": "user",
      "description": "[GATE] Echo chain — pops queued follow-up commands and re-injects them as block reasons to continue the session"
    },
    {
      "id": "stop-push-gate",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/gates/stop-push-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if worker branch has unpushed commits or uncommitted changes. Ensures work is preserved"
    },
    {
      "id": "stop-cron-gate",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/gates/stop-cron-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if worker has cron_schedule configured but hasn't called CronCreate with expected parameters"
    },

    {"_comment": "── Liveness heartbeat (ALL events) ──"},

    {
      "id": "liveness-heartbeat-pre-tool",
      "event": "PreToolUse",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on PreToolUse — ensures watchdog sees activity during tool selection"
    },
    {
      "id": "liveness-heartbeat-subagent-start",
      "event": "SubagentStart",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on SubagentStart — prevents stuck detection during subagent spawning"
    },
    {
      "id": "liveness-heartbeat-subagent-stop",
      "event": "SubagentStop",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on SubagentStop — signals subagent lifecycle activity"
    },
    {
      "id": "liveness-heartbeat-pre-compact",
      "event": "PreCompact",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on PreCompact — prevents stuck detection during context compaction"
    },
    {
      "id": "liveness-heartbeat-session-start",
      "event": "SessionStart",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on SessionStart — initializes liveness tracking"
    },
    {
      "id": "liveness-heartbeat-session-end",
      "event": "SessionEnd",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on SessionEnd — signals clean session teardown"
    },
    {
      "id": "liveness-heartbeat-instructions",
      "event": "InstructionsLoaded",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on InstructionsLoaded — confirms worker is parsing config"
    },
    {
      "id": "liveness-heartbeat-permission",
      "event": "PermissionRequest",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on PermissionRequest — prevents stuck detection while awaiting approval"
    },
    {
      "id": "liveness-heartbeat-post-fail",
      "event": "PostToolUseFailure",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on PostToolUseFailure — signals worker is handling errors"
    },
    {
      "id": "liveness-heartbeat-notification",
      "event": "Notification",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on Notification — signals worker is processing notifications"
    },
    {
      "id": "liveness-heartbeat-teammate",
      "event": "TeammateIdle",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on TeammateIdle — prevents stuck detection during team coordination"
    },
    {
      "id": "liveness-heartbeat-task",
      "event": "TaskCompleted",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on TaskCompleted — signals task completion activity"
    },
    {
      "id": "liveness-heartbeat-config",
      "event": "ConfigChange",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on ConfigChange — signals config update activity"
    },
    {
      "id": "liveness-heartbeat-worktree-create",
      "event": "WorktreeCreate",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on WorktreeCreate — prevents stuck detection during worktree operations"
    },
    {
      "id": "liveness-heartbeat-worktree-remove",
      "event": "WorktreeRemove",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on WorktreeRemove — signals worktree cleanup activity"
    },

    {"_comment": "── Universal infrastructure (ALL events) ──"},

    {
      "id": "universal-logger-session-start",
      "event": "SessionStart",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs SessionStart event to event bus with timestamp, session ID, and worker name"
    },
    {
      "id": "universal-logger-session-end",
      "event": "SessionEnd",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs SessionEnd event to event bus with timestamp and session ID"
    },
    {
      "id": "universal-logger-instructions-loaded",
      "event": "InstructionsLoaded",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs InstructionsLoaded event — confirms CLAUDE.md was parsed"
    },
    {
      "id": "universal-logger-permission-request",
      "event": "PermissionRequest",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs PermissionRequest event — records when user is prompted for tool approval"
    },
    {
      "id": "universal-logger-post-tool-use-failure",
      "event": "PostToolUseFailure",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs PostToolUseFailure — records tool failures for debugging and pattern detection"
    },
    {
      "id": "universal-logger-notification",
      "event": "Notification",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs system Notification events to event bus"
    },
    {
      "id": "universal-logger-teammate-idle",
      "event": "TeammateIdle",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs TeammateIdle event — records when a team member goes idle for coordination"
    },
    {
      "id": "universal-logger-task-completed",
      "event": "TaskCompleted",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs TaskCompleted event — records task completions for downstream chaining"
    },
    {
      "id": "universal-logger-config-change",
      "event": "ConfigChange",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs ConfigChange event — records settings modifications"
    },
    {
      "id": "universal-logger-worktree-create",
      "event": "WorktreeCreate",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs WorktreeCreate event — records when isolated worktrees are created for subagents"
    },
    {
      "id": "universal-logger-worktree-remove",
      "event": "WorktreeRemove",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs WorktreeRemove event — records when worktrees are cleaned up"
    },

    {
      "id": "git-hooks-installer",
      "event": "SessionStart",
      "path": "~/.claude-fleet/hooks/interceptors/git-hooks-installer.sh",
      "required": true,
      "category": "core",
      "description": "[INJECT] Auto-installs git pre-commit hooks from manifest on session start"
    }
  ]
}
