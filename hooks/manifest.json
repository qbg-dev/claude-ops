{
  "_comment": "Canonical hook registry. setup-hooks.sh reads this to install into ~/.claude/settings.json. lint-hooks.sh reads this to verify installation.",
  "hooks": [
    {
      "id": "session-auto-register",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/hooks/publishers/session-auto-register.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Auto-registers any Claude session with Fleet Mail on first prompt (session-first identity)"
    },
    {
      "id": "session-file-sync",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/hooks/publishers/session-file-sync.sh",
      "required": false,
      "category": "core",
      "description": "[PUBLISH] Syncs session transcript to Fleet Mail server every 5 minutes"
    },
    {
      "id": "worker-session-register",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/hooks/publishers/worker-session-register.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Registers worker's tmux pane and session in fleet registry on each prompt (legacy)"
    },
    {
      "id": "snippet-injector",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/plugins/claude-context-orchestrator/scripts/snippets/snippet_injector.py",
      "runner": "python3",
      "matcher": ".*",
      "required": false,
      "category": "plugin",
      "description": "[INJECT] Injects contextual snippets into prompts based on keyword matching"
    },
    {
      "id": "prompt-publisher",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/hooks/publishers/prompt-publisher.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Emits prompt events to event bus for watchdog liveness and coordinator inbox routing"
    },
    {
      "id": "prompt-echo-deferred",
      "event": "UserPromptSubmit",
      "path": "~/.claude-fleet/hooks/publishers/prompt-echo-deferred.sh",
      "required": false,
      "category": "user",
      "description": "[INJECT] Deferred echo chain \u2014 feeds queued follow-up prompts from stop-echo.sh back into the session"
    },
    {
      "id": "pii-firewall",
      "event": "PreToolUse",
      "path": "{PROJECT_ROOT}/.claude/hooks/pii-firewall.sh",
      "required": false,
      "category": "project",
      "description": "[GATE] Blocks direct access to customer conversation content for PIPL compliance. Requires qwen-analyst MCP for data analysis"
    },
    {
      "id": "tool-policy-gate",
      "event": "PreToolUse",
      "path": "~/.claude-fleet/hooks/gates/tool-policy-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Enforces per-worker tool deny-list from permissions.json. Blocks matching tool calls with explanation"
    },
    {
      "id": "git-safety-gate",
      "event": "PreToolUse",
      "path": "~/.claude-fleet/hooks/gates/git-safety-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks dangerous git operations: --amend (use new commits), branch names not matching worker/*, direct prod SSH"
    },
    {
      "id": "pre-tool-context-injector",
      "event": "PreToolUse",
      "path": "~/.claude-fleet/hooks/interceptors/pre-tool-context-injector.sh",
      "required": true,
      "category": "core",
      "description": "[INJECT] Injects policy hints, inbox scan, phase context, and subagent agent_id before each tool call"
    },
    {
      "id": "subagent-start",
      "event": "SubagentStart",
      "path": "~/.claude-fleet/hooks/publishers/subagent-lifecycle.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Tracks subagent spawn for resource management and auto-completion of agent-scoped hooks"
    },
    {
      "id": "subagent-stop",
      "event": "SubagentStop",
      "path": "~/.claude-fleet/hooks/publishers/subagent-lifecycle.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Tracks subagent exit \u2014 auto-completes dynamic hooks scoped to this agent_id"
    },
    {
      "id": "pre-compact",
      "event": "PreCompact",
      "path": "~/.claude-fleet/scripts/pre-compact.sh",
      "timeout": 5000,
      "required": true,
      "category": "core",
      "description": "[INJECT] Re-injects seed template, worker state, and task queue before context compaction to prevent amnesia"
    },
    {
      "id": "liveness-heartbeat-stop",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on session stop \u2014 signals clean exit to watchdog"
    },
    {
      "id": "stop-worker-dispatch",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/gates/stop-worker-dispatch.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if worker has in-progress tasks. Ensures work is completed or handed off before stopping"
    },
    {
      "id": "stop-inbox-drain",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/gates/stop-inbox-drain.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if unread BMS messages or pending ACKs exist. Ensures inbox is drained before stopping"
    },
    {
      "id": "stop-echo",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/publishers/stop-echo.sh",
      "required": false,
      "category": "user",
      "description": "[GATE] Echo chain \u2014 pops queued follow-up commands and re-injects them as block reasons to continue the session"
    },
    {
      "id": "stop-push-gate",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/gates/stop-push-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if worker branch has unpushed commits or uncommitted changes. Ensures work is preserved"
    },
    {
      "id": "stop-cron-gate",
      "event": "Stop",
      "path": "~/.claude-fleet/hooks/gates/stop-cron-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if worker has cron_schedule configured but hasn't called CronCreate with expected parameters"
    },
    {
      "_comment": "\u2500\u2500 Liveness heartbeat (ALL events) \u2500\u2500"
    },
    {
      "id": "liveness-heartbeat-pre-tool",
      "event": "PreToolUse",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on PreToolUse \u2014 ensures watchdog sees activity during tool selection"
    },
    {
      "id": "liveness-heartbeat-session-start",
      "event": "SessionStart",
      "path": "~/.claude-fleet/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on SessionStart \u2014 initializes liveness tracking"
    },
    {
      "_comment": "\u2500\u2500 Universal infrastructure (ALL events) \u2500\u2500"
    },
    {
      "id": "universal-logger-session-start",
      "event": "SessionStart",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs SessionStart event to event bus with timestamp, session ID, and worker name"
    },
    {
      "id": "universal-logger-session-end",
      "event": "SessionEnd",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs SessionEnd event to event bus with timestamp and session ID"
    },
    {
      "id": "universal-logger-instructions-loaded",
      "event": "InstructionsLoaded",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs InstructionsLoaded event \u2014 confirms CLAUDE.md was parsed"
    },
    {
      "id": "universal-logger-permission-request",
      "event": "PermissionRequest",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs PermissionRequest event \u2014 records when user is prompted for tool approval"
    },
    {
      "id": "universal-logger-post-tool-use-failure",
      "event": "PostToolUseFailure",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs PostToolUseFailure \u2014 records tool failures for debugging and pattern detection"
    },
    {
      "id": "universal-logger-notification",
      "event": "Notification",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs system Notification events to event bus"
    },
    {
      "id": "universal-logger-teammate-idle",
      "event": "TeammateIdle",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs TeammateIdle event \u2014 records when a team member goes idle for coordination"
    },
    {
      "id": "universal-logger-task-completed",
      "event": "TaskCompleted",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs TaskCompleted event \u2014 records task completions for downstream chaining"
    },
    {
      "id": "universal-logger-config-change",
      "event": "ConfigChange",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs ConfigChange event \u2014 records settings modifications"
    },
    {
      "id": "universal-logger-worktree-create",
      "event": "WorktreeCreate",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs WorktreeCreate event \u2014 records when isolated worktrees are created for subagents"
    },
    {
      "id": "universal-logger-worktree-remove",
      "event": "WorktreeRemove",
      "path": "~/.claude-fleet/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs WorktreeRemove event \u2014 records when worktrees are cleaned up"
    },
    {
      "id": "git-hooks-installer",
      "event": "SessionStart",
      "path": "~/.claude-fleet/hooks/interceptors/git-hooks-installer.sh",
      "required": true,
      "category": "core",
      "description": "[INJECT] Auto-installs git pre-commit hooks from manifest on session start"
    },
    {
      "id": "session-start-config-seed",
      "event": "SessionStart",
      "path": "~/.claude-fleet/hooks/interceptors/session-start-config-seed.sh",
      "required": false,
      "category": "core",
      "description": "[INJECT] Injects config-driven seed fragments on session start (e.g. cron_schedule enforcement)"
    }
  ]
}
