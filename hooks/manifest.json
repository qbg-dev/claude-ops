{
  "_comment": "Canonical hook registry. setup-hooks.sh reads this to install into ~/.claude/settings.json. lint-hooks.sh reads this to verify installation.",
  "hooks": [
    {
      "id": "worker-session-register",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/hooks/publishers/worker-session-register.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Registers worker's tmux pane and session in fleet registry on each prompt"
    },
    {
      "id": "snippet-injector",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/plugins/claude-context-orchestrator/scripts/snippets/snippet_injector.py",
      "runner": "python3",
      "matcher": ".*",
      "required": false,
      "category": "plugin",
      "description": "[INJECT] Injects contextual snippets into prompts based on keyword matching"
    },
    {
      "id": "prompt-publisher",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/hooks/publishers/prompt-publisher.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Emits prompt events to event bus for watchdog liveness and coordinator inbox routing"
    },
    {
      "id": "prompt-echo-deferred",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/hooks/publishers/prompt-echo-deferred.sh",
      "required": false,
      "category": "user",
      "description": "[INJECT] Deferred echo chain — feeds queued follow-up prompts from stop-echo.sh back into the session"
    },
    {
      "id": "pii-firewall",
      "event": "PreToolUse",
      "path": "{PROJECT_ROOT}/.claude/hooks/pii-firewall.sh",
      "required": false,
      "category": "project",
      "description": "[GATE] Blocks direct access to customer conversation content for PIPL compliance. Requires qwen-analyst MCP for data analysis"
    },
    {
      "id": "tool-policy-gate",
      "event": "PreToolUse",
      "path": "~/.claude-ops/hooks/gates/tool-policy-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Enforces per-worker tool deny-list from permissions.json. Blocks matching tool calls with explanation"
    },
    {
      "id": "git-safety-gate",
      "event": "PreToolUse",
      "path": "~/.claude-ops/hooks/gates/git-safety-gate.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks dangerous git operations: --amend (use new commits), branch names not matching worker/*, direct prod SSH"
    },
    {
      "id": "pre-tool-context-injector",
      "event": "PreToolUse",
      "path": "~/.claude-ops/hooks/interceptors/pre-tool-context-injector.sh",
      "required": true,
      "category": "core",
      "description": "[INJECT] Injects policy hints, inbox scan, phase context, and subagent agent_id before each tool call"
    },
    {
      "id": "liveness-heartbeat-post",
      "event": "PostToolUse",
      "path": "~/.claude-ops/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp after each tool call — watchdog uses this for stuck detection (>10min = stuck)"
    },
    {
      "id": "liveness-heartbeat-prompt",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on prompt submit — watchdog uses this for stuck detection (>10min = stuck)"
    },
    {
      "id": "subagent-start",
      "event": "SubagentStart",
      "path": "~/.claude-ops/hooks/publishers/subagent-lifecycle.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Tracks subagent spawn for resource management and auto-completion of agent-scoped hooks"
    },
    {
      "id": "subagent-stop",
      "event": "SubagentStop",
      "path": "~/.claude-ops/hooks/publishers/subagent-lifecycle.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Tracks subagent exit — auto-completes dynamic hooks scoped to this agent_id"
    },
    {
      "id": "pre-compact",
      "event": "PreCompact",
      "path": "~/.claude-ops/scripts/pre-compact.sh",
      "timeout": 5000,
      "required": true,
      "category": "core",
      "description": "[INJECT] Re-injects seed template, worker state, and task queue before context compaction to prevent amnesia"
    },
    {
      "id": "liveness-heartbeat-stop",
      "event": "Stop",
      "path": "~/.claude-ops/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "[PUBLISH] Touches liveness timestamp on session stop — signals clean exit to watchdog"
    },
    {
      "id": "stop-worker-dispatch",
      "event": "Stop",
      "path": "~/.claude-ops/hooks/gates/stop-worker-dispatch.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if worker has in-progress tasks. Ensures work is completed or handed off before stopping"
    },
    {
      "id": "stop-inbox-drain",
      "event": "Stop",
      "path": "~/.claude-ops/hooks/gates/stop-inbox-drain.sh",
      "required": true,
      "category": "core",
      "description": "[GATE] Blocks session exit if unread BMS messages or pending ACKs exist. Ensures inbox is drained before stopping"
    },
    {
      "id": "stop-echo",
      "event": "Stop",
      "path": "~/.claude-ops/hooks/publishers/stop-echo.sh",
      "required": false,
      "category": "user",
      "description": "[GATE] Echo chain — pops queued follow-up commands and re-injects them as block reasons to continue the session"
    },

    {"_comment": "── Universal infrastructure (ALL events) ──"},

    {
      "id": "universal-logger-session-start",
      "event": "SessionStart",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs SessionStart event to event bus with timestamp, session ID, and worker name"
    },
    {
      "id": "universal-logger-session-end",
      "event": "SessionEnd",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs SessionEnd event to event bus with timestamp and session ID"
    },
    {
      "id": "universal-logger-instructions-loaded",
      "event": "InstructionsLoaded",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs InstructionsLoaded event — confirms CLAUDE.md was parsed"
    },
    {
      "id": "universal-logger-permission-request",
      "event": "PermissionRequest",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs PermissionRequest event — records when user is prompted for tool approval"
    },
    {
      "id": "universal-logger-post-tool-use-failure",
      "event": "PostToolUseFailure",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs PostToolUseFailure — records tool failures for debugging and pattern detection"
    },
    {
      "id": "universal-logger-notification",
      "event": "Notification",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs system Notification events to event bus"
    },
    {
      "id": "universal-logger-teammate-idle",
      "event": "TeammateIdle",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs TeammateIdle event — records when a team member goes idle for coordination"
    },
    {
      "id": "universal-logger-task-completed",
      "event": "TaskCompleted",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs TaskCompleted event — records task completions for downstream chaining"
    },
    {
      "id": "universal-logger-config-change",
      "event": "ConfigChange",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs ConfigChange event — records settings modifications"
    },
    {
      "id": "universal-logger-worktree-create",
      "event": "WorktreeCreate",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs WorktreeCreate event — records when isolated worktrees are created for subagents"
    },
    {
      "id": "universal-logger-worktree-remove",
      "event": "WorktreeRemove",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "[LOG] Logs WorktreeRemove event — records when worktrees are cleaned up"
    },

    {"_comment": "── Dynamic hook dispatcher (ALL events) ──"},

    {
      "id": "git-hooks-installer",
      "event": "SessionStart",
      "path": "~/.claude-ops/hooks/interceptors/git-hooks-installer.sh",
      "required": true,
      "category": "core",
      "description": "[INJECT] Auto-installs git pre-commit hooks from manifest on session start"
    },
    {
      "id": "dynamic-hooks-session-start",
      "event": "SessionStart",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks registered via add_hook() for SessionStart events"
    },
    {
      "id": "dynamic-hooks-session-end",
      "event": "SessionEnd",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for SessionEnd events"
    },
    {
      "id": "dynamic-hooks-user-prompt",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for UserPromptSubmit events"
    },
    {
      "id": "dynamic-hooks-pre-tool-use",
      "event": "PreToolUse",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for PreToolUse — supports tool/file_glob/command_pattern conditions"
    },
    {
      "id": "dynamic-hooks-permission-request",
      "event": "PermissionRequest",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for PermissionRequest events"
    },
    {
      "id": "dynamic-hooks-post-tool-use",
      "event": "PostToolUse",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for PostToolUse events"
    },
    {
      "id": "dynamic-hooks-post-tool-use-failure",
      "event": "PostToolUseFailure",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for PostToolUseFailure events"
    },
    {
      "id": "dynamic-hooks-notification",
      "event": "Notification",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for Notification events"
    },
    {
      "id": "dynamic-hooks-stop",
      "event": "Stop",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for Stop events — blocks exit if any blocking hooks are pending"
    },
    {
      "id": "dynamic-hooks-subagent-start",
      "event": "SubagentStart",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for SubagentStart events"
    },
    {
      "id": "dynamic-hooks-subagent-stop",
      "event": "SubagentStop",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for SubagentStop events — auto-completes agent-scoped hooks"
    },
    {
      "id": "dynamic-hooks-teammate-idle",
      "event": "TeammateIdle",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for TeammateIdle events"
    },
    {
      "id": "dynamic-hooks-task-completed",
      "event": "TaskCompleted",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for TaskCompleted events"
    },
    {
      "id": "dynamic-hooks-config-change",
      "event": "ConfigChange",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for ConfigChange events"
    },
    {
      "id": "dynamic-hooks-pre-compact",
      "event": "PreCompact",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for PreCompact events"
    },
    {
      "id": "dynamic-hooks-worktree-create",
      "event": "WorktreeCreate",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for WorktreeCreate events"
    },
    {
      "id": "dynamic-hooks-worktree-remove",
      "event": "WorktreeRemove",
      "path": "~/.claude-ops/hooks/interceptors/dynamic-hook-dispatcher.sh",
      "required": true,
      "category": "core",
      "description": "[DISPATCH] Evaluates dynamic hooks for WorktreeRemove events"
    }
  ]
}
