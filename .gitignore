# Runtime state (agent-specific, not portable)
state/
harness/manifests/
harness/reports/
harness/data/
wave-report-server/registry.json
wave-report-server/issues/

# Project-specific runtime
.claude/bus/
.claude/scripts/
# Allow oss-steward seed (dogfooding)
!.claude/scripts/oss-steward-seed.sh

# Harness runtime files (inbox/outbox are ephemeral)
.claude/harness/*/agents/*/inbox.jsonl
.claude/harness/*/agents/*/outbox.jsonl
.claude/harness/*/agents/*/memory/
.claude/harness/*/vision.html
.claude/harness/*/report.css
.claude/harness/*/wave-*.html

# Event bus runtime data
bus/stream.jsonl
bus/seq.json
bus/cursors/
bus/dlq/
bus/topics/

# Credentials (contains OAuth secrets)
lib/google-auth.sh

# Plugins (user-specific)
plugins/

# macOS
.DS_Store

# Editor
*.swp
*.swo
*~
