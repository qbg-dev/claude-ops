  "model": "sonnet",
  "permission_mode": "bypassPermissions",
  "disallowedTools": [
    "Edit",
    "Write",
    "NotebookEdit",
    "Bash(git push*)",
    "Bash(git checkout main*)",
    "Bash(git merge*)",
    "Bash(git reset --hard*)",
    "Bash(git clean*)",
    "Bash(rm -rf*)",
    "Bash(*deploy*prod*)",
    "Bash(*INSERT*INTO*)",
    "Bash(*UPDATE*SET*)",
    "Bash(*DELETE*FROM*)",
    "Bash(*DROP*TABLE*)",
    "Bash(*ALTER*TABLE*)"
  ]
}
