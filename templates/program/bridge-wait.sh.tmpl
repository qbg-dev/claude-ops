#!/usr/bin/env bash
# Bridge wait script — blocks on FIFO until Stop hook triggers.
# Auto-generated by Program API.
echo "═══ Bridge: {{LABEL}} ═══"
echo "Waiting for Stop hook to trigger..."
echo "Blocked on: {{FIFO_PATH}}"
echo ""
mkfifo '{{FIFO_PATH}}' 2>/dev/null || true
cat '{{FIFO_PATH}}' > /dev/null
echo "$(date '+%H:%M:%S') Hook received. Running bridge..."
