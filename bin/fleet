#!/usr/bin/env bash
# fleet — Worker fleet management CLI (TypeScript, powered by citty + Bun)
#
# Thin shim that delegates to the TypeScript CLI.
# Bash implementation preserved at bin/fleet.bash.bak.
#
# Usage: fleet <command> [args] [flags]
#   fleet --help    Show all commands

set -euo pipefail

FLEET_DIR="${CLAUDE_FLEET_DIR:-${CLAUDE_OPS_DIR:-$HOME/.claude-fleet}}"
CLI_ENTRY="$FLEET_DIR/cli/index.ts"

# Resolve bun
BUN="${BUN:-$(command -v bun 2>/dev/null || echo "")}"
if [ -z "$BUN" ]; then
  echo "ERROR: bun not found. Install: curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi

exec "$BUN" run "$CLI_ENTRY" "$@"
