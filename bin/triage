#!/usr/bin/env bun
/**
 * triage — Global decision queue TUI (vim-style navigation)
 *
 * Workers escalate decisions → queue.jsonl → notify fires → user responds here → inbox delivery.
 *
 * Usage: triage              (interactive TUI, auto-refreshes)
 *        triage --add "title" "detail" --from worker-name
 *
 * Keys: j/k navigate, Enter respond, d dismiss, h history, r refresh, q quit
 */

import { readFileSync, writeFileSync, appendFileSync, existsSync, mkdirSync } from "fs";
import { execSync } from "child_process";
import { createInterface } from "readline";
import { join, dirname, basename } from "path";

// --- Find repo root by walking up ---
function findRepoRoot(): string {
  let dir = process.cwd();
  while (dir !== "/") {
    if (existsSync(join(dir, ".claude", "triage")) || existsSync(join(dir, ".claude", "workers"))) return dir;
    if (existsSync(join(dir, "CLAUDE.md"))) return dir;
    dir = dirname(dir);
  }
  console.error("Error: Could not find repo root (no .claude/ directory found walking up from cwd)");
  process.exit(1);
}

const ROOT = findRepoRoot();
const PROJECT = basename(ROOT);
const TRIAGE_DIR = join(ROOT, ".claude", "triage");
const QUEUE_FILE = join(TRIAGE_DIR, "queue.jsonl");
const HISTORY_FILE = join(TRIAGE_DIR, "history.jsonl");
const WORKERS_DIR = join(ROOT, ".claude", "workers");
mkdirSync(TRIAGE_DIR, { recursive: true });

interface TriageItem {
  id: string;
  category: string;
  title: string;
  detail: string;
  source?: string;
  from_worker?: string;
  reply_to_msg_id?: string;
  options?: string[];
  urgency?: string;
  added_at: string;
  status: "pending" | "resolved";
  response?: string;
  responded_at?: string;
}

// --- Colors (matches Warren's gold/cyan/magenta palette) ---
const C = {
  reset: "\x1b[0m", bold: "\x1b[1m", dim: "\x1b[2m", inverse: "\x1b[7m",
  red: "\x1b[31m", green: "\x1b[32m", yellow: "\x1b[33m",
  blue: "\x1b[34m", magenta: "\x1b[35m", cyan: "\x1b[36m", white: "\x1b[37m",
  gold: "\x1b[38;5;178m",      // Warren's accent color
  bgGold: "\x1b[48;5;178m",
  gray: "\x1b[38;5;242m",
  bgDark: "\x1b[48;5;235m",
};

const CATEGORY_COLORS: Record<string, string> = {
  "product-decision": C.magenta, "bug-assignment": C.red, "worker-escalation": C.yellow,
  "worker-question": C.blue, "notification": C.gray, architecture: C.cyan,
  coordination: C.yellow, question: C.blue,
};

// --- Data ---
function loadQueue(): TriageItem[] {
  if (!existsSync(QUEUE_FILE)) return [];
  const content = readFileSync(QUEUE_FILE, "utf-8").trim();
  if (!content) return [];
  return content.split("\n").filter(Boolean).map((l) => JSON.parse(l));
}

function loadHistory(limit = 10): TriageItem[] {
  if (!existsSync(HISTORY_FILE)) return [];
  const lines = readFileSync(HISTORY_FILE, "utf-8").trim().split("\n").filter(Boolean);
  return lines.slice(-limit).reverse().map((l) => JSON.parse(l));
}

function saveQueue(items: TriageItem[]) {
  writeFileSync(QUEUE_FILE, items.map((i) => JSON.stringify(i)).join("\n") + (items.length ? "\n" : ""));
}

// --- Formatting ---
function timeSince(iso: string): string {
  const diff = Date.now() - new Date(iso).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return "now";
  if (mins < 60) return `${mins}m`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h`;
  return `${Math.floor(hours / 24)}d`;
}

function catLabel(cat: string): string {
  return `${CATEGORY_COLORS[cat] || C.white}${cat}${C.reset}`;
}

function urgencyMark(u?: string): string {
  if (u === "high") return `${C.red}${C.bold}▲${C.reset} `;
  if (u === "low") return `${C.dim}▽ ${C.reset}`;
  return "";
}

function wordWrap(text: string, width: number): string[] {
  const result: string[] = [];
  for (const paragraph of text.split("\n")) {
    if (paragraph.length <= width) { result.push(paragraph); continue; }
    let line = "";
    for (const word of paragraph.split(" ")) {
      if (line.length + word.length + 1 > width) { result.push(line); line = word; }
      else { line = line ? `${line} ${word}` : word; }
    }
    if (line) result.push(line);
  }
  return result;
}

// --- Inbox delivery ---
function sendToWorkerInbox(workerName: string, response: string, item: TriageItem) {
  const inboxFile = join(WORKERS_DIR, workerName, "inbox.jsonl");
  if (!existsSync(dirname(inboxFile))) return false;
  const msg = {
    msg_id: `triage-${item.id}-${Date.now().toString(36)}`,
    to: `worker/${workerName}`,
    from: "user", from_name: "User",
    content: `[Triage Decision] ${item.title}\n\nDecision: ${response}`,
    summary: `decision: ${response.slice(0, 50)}`,
    ack_required: false,
    in_reply_to: item.reply_to_msg_id || null,
    msg_type: "triage-response",
    channel: "triage-tui",
    _ts: new Date().toISOString(),
  };
  appendFileSync(inboxFile, JSON.stringify(msg) + "\n");
  // tmux delivery (best-effort)
  try {
    const regPath = join(WORKERS_DIR, "registry.json");
    if (existsSync(regPath)) {
      const reg = JSON.parse(readFileSync(regPath, "utf-8"));
      const paneId = reg[workerName]?.pane_id;
      if (paneId) {
        const escaped = `[TRIAGE] Decision: ${response.slice(0, 80)}`.replace(/'/g, "'\\''");
        execSync(`tmux display-message -t ${paneId} '${escaped}'`, { stdio: "pipe" });
      }
    }
  } catch {}
  return true;
}

function sendToChiefInbox(response: string, item: TriageItem) {
  const inboxFile = join(WORKERS_DIR, "chief-of-staff", "inbox.jsonl");
  if (!existsSync(dirname(inboxFile))) return;
  appendFileSync(inboxFile, JSON.stringify({
    msg_id: `triage-${item.id}-cos-${Date.now().toString(36)}`,
    to: "worker/chief-of-staff", from: "user", from_name: "User",
    content: `[Triage Decision] ${item.title}\nSource: ${item.source || "n/a"}\nCategory: ${item.category}\n\nDecision: ${response}`,
    summary: `triage: ${item.title.slice(0, 40)}`,
    ack_required: false, msg_type: "message", channel: "triage-tui",
    _ts: new Date().toISOString(),
  }) + "\n");
}

function appendToHistory(item: TriageItem) {
  appendFileSync(HISTORY_FILE, JSON.stringify(item) + "\n");
}

// --- CLI: --add mode ---
if (process.argv.includes("--add")) {
  const args = process.argv.slice(2);
  const titleIdx = args.indexOf("--add");
  const title = args[titleIdx + 1];
  const detail = args[titleIdx + 2] || "";
  const fromIdx = args.indexOf("--from");
  const fromWorker = fromIdx >= 0 ? args[fromIdx + 1] : undefined;
  const categoryIdx = args.indexOf("--category");
  const category = categoryIdx >= 0 ? args[categoryIdx + 1] : "worker-escalation";
  appendFileSync(QUEUE_FILE, JSON.stringify({
    id: `tq-${Date.now().toString(36)}`, category, title, detail,
    source: fromWorker, from_worker: fromWorker,
    added_at: new Date().toISOString(), status: "pending",
  } satisfies TriageItem) + "\n");
  console.log(`Added: ${title}`);
  process.exit(0);
}

// ═══════════════════════════════════════════════════════════════════
// INTERACTIVE TUI — raw terminal, vim-style navigation
// ═══════════════════════════════════════════════════════════════════

let cursor = 0;
let items = loadQueue();
let showHistory = false;
let mode: "list" | "respond" = "list";
const cols = process.stdout.columns || 100;
const sep = C.dim + "─".repeat(Math.min(cols - 4, 90)) + C.reset;

function getPending(): TriageItem[] {
  return items.filter((i) => i.status === "pending");
}

function render() {
  const pending = getPending();
  const lines: string[] = [];

  // Header
  const countLabel = pending.length > 0
    ? `${C.gold}${C.bold}${pending.length}${C.reset}${C.dim} pending`
    : `${C.green}0${C.reset}${C.dim} pending`;
  lines.push(`  ${C.bold}${C.gold}TRIAGE${C.reset}  ${countLabel}  ${C.gray}${PROJECT}${C.reset}`);
  lines.push("");

  if (showHistory) {
    const hist = loadHistory(8);
    if (hist.length === 0) {
      lines.push(`  ${C.dim}No history yet.${C.reset}`);
    } else {
      lines.push(`  ${C.dim}Recent decisions:${C.reset}`);
      for (const h of hist) {
        const age = timeSince(h.responded_at || h.added_at);
        lines.push(`  ${C.dim}${age}${C.reset}  ${C.gray}${h.title.slice(0, 50)}${C.reset}  ${C.green}→ ${(h.response || "").slice(0, 40)}${C.reset}`);
      }
    }
    lines.push("");
    lines.push(`  ${sep}`);
    lines.push(`  ${C.dim}h${C.reset} back  ${C.dim}q${C.reset} quit`);
  } else if (pending.length === 0) {
    lines.push(`  ${C.dim}No pending items. Watching for new escalations...${C.reset}`);
    lines.push("");
    lines.push(`  ${sep}`);
    lines.push(`  ${C.dim}h${C.reset} history  ${C.dim}r${C.reset} refresh  ${C.dim}q${C.reset} quit`);
  } else {
    // Item list
    for (let i = 0; i < pending.length; i++) {
      const item = pending[i];
      const selected = i === cursor;
      const age = timeSince(item.added_at);
      const from = item.from_worker ? `${C.green}@${item.from_worker}${C.reset}` : "";
      const urg = urgencyMark(item.urgency);
      const prefix = selected ? `${C.gold}${C.bold} ▸ ${C.reset}` : "   ";
      const numStyle = selected ? `${C.gold}${C.bold}` : C.dim;
      const titleStyle = selected ? `${C.bold}${C.white}` : "";

      lines.push(`${prefix}${numStyle}${i + 1}.${C.reset} ${urg}${titleStyle}${item.title}${C.reset}  ${catLabel(item.category)}  ${from}  ${C.dim}${age}${C.reset}`);
    }

    // Detail pane for selected item
    const sel = pending[cursor];
    if (sel) {
      lines.push("");
      lines.push(`  ${sep}`);
      lines.push(`  ${C.bold}${sel.title}${C.reset}`);
      const meta: string[] = [];
      if (sel.from_worker) meta.push(`${C.green}@${sel.from_worker}${C.reset}`);
      meta.push(catLabel(sel.category));
      meta.push(`${C.dim}${timeSince(sel.added_at)} ago${C.reset}`);
      if (sel.urgency === "high") meta.push(`${C.red}${C.bold}URGENT${C.reset}`);
      lines.push(`  ${meta.join("  ")}`);
      lines.push("");

      // Detail text
      const detailWidth = Math.min(cols - 6, 86);
      for (const line of wordWrap(sel.detail, detailWidth)) {
        lines.push(`  ${line}`);
      }

      // Options
      if (sel.options?.length) {
        lines.push("");
        lines.push(`  ${C.yellow}Options:${C.reset}`);
        sel.options.forEach((opt, j) => {
          lines.push(`    ${C.bold}${C.cyan}${j + 1})${C.reset} ${opt}`);
        });
      }
    }

    lines.push("");
    lines.push(`  ${sep}`);
    lines.push(`  ${C.dim}j${C.reset}/${C.dim}k${C.reset} navigate  ${C.dim}Enter${C.reset} respond  ${C.dim}d${C.reset} dismiss  ${C.dim}h${C.reset} history  ${C.dim}r${C.reset} refresh  ${C.dim}q${C.reset} quit`);
  }

  // Clear screen and write
  process.stdout.write("\x1b[2J\x1b[H");
  process.stdout.write(lines.join("\n") + "\n");
}

// --- Response mode (drops to readline) ---
async function respondToItem(item: TriageItem) {
  mode = "respond";
  process.stdin.setRawMode(false);

  const rl = createInterface({ input: process.stdin, output: process.stdout });
  const ask = (q: string): Promise<string> => new Promise((r) => rl.question(q, r));

  process.stdout.write("\n");
  process.stdout.write(`  ${C.bold}Responding to:${C.reset} ${item.title}\n`);
  if (item.from_worker) process.stdout.write(`  ${C.dim}From: @${item.from_worker}${C.reset}\n`);

  if (item.options?.length) {
    process.stdout.write(`  ${C.yellow}Options:${C.reset}\n`);
    item.options.forEach((opt, j) => process.stdout.write(`    ${C.bold}${C.cyan}${j + 1})${C.reset} ${opt}\n`));
    process.stdout.write(`  ${C.dim}Enter option number, or type a custom response (empty line to finish):${C.reset}\n`);
  } else {
    process.stdout.write(`  ${C.dim}Type your decision (empty line to finish):${C.reset}\n`);
  }

  const lines: string[] = [];
  while (true) {
    const line = await ask(`  ${C.gold}│${C.reset} `);
    if (line === "" && lines.length > 0) break;
    if (line !== "") lines.push(line);
  }
  rl.close();

  let response = lines.join("\n");

  // Numeric option selection
  if (item.options?.length && lines.length === 1) {
    const optNum = parseInt(lines[0]);
    if (!isNaN(optNum) && optNum >= 1 && optNum <= item.options.length) {
      response = item.options[optNum - 1];
      process.stdout.write(`  ${C.dim}→ Selected: ${response}${C.reset}\n`);
    }
  }

  // Resolve
  item.status = "resolved";
  item.response = response;
  item.responded_at = new Date().toISOString();
  saveQueue(items);
  appendToHistory(item);

  // Route response
  if (item.from_worker) {
    const ok = sendToWorkerInbox(item.from_worker, response, item);
    process.stdout.write(`  ${C.green}✓ Sent to @${item.from_worker}${ok ? "" : " (inbox dir missing)"}${C.reset}\n`);
  }
  sendToChiefInbox(response, item);
  process.stdout.write(`  ${C.green}✓ Sent to chief-of-staff${C.reset}\n`);

  await new Promise((r) => setTimeout(r, 800));

  // Back to list mode
  mode = "list";
  items = loadQueue();
  cursor = Math.min(cursor, Math.max(0, getPending().length - 1));
  process.stdin.setRawMode(true);
  render();
}

function dismissItem(item: TriageItem) {
  item.status = "resolved";
  item.response = "(dismissed)";
  item.responded_at = new Date().toISOString();
  saveQueue(items);
  appendToHistory(item);

  if (item.from_worker) {
    sendToWorkerInbox(item.from_worker, "(dismissed — no action needed)", item);
  }

  items = loadQueue();
  cursor = Math.min(cursor, Math.max(0, getPending().length - 1));
  render();
}

// --- Auto-refresh (poll every 3s) ---
let lastCount = 0;
setInterval(() => {
  if (mode !== "list") return;
  const fresh = loadQueue();
  const newPending = fresh.filter((i) => i.status === "pending").length;
  if (newPending !== lastCount) {
    items = fresh;
    lastCount = newPending;
    cursor = Math.min(cursor, Math.max(0, newPending - 1));
    render();
  }
}, 3000);

// --- Raw input handler ---
if (!process.stdin.isTTY) {
  console.error("Error: triage requires an interactive terminal (TTY)");
  process.exit(1);
}
process.stdin.setRawMode(true);
process.stdin.resume();
process.stdin.setEncoding("utf-8");

lastCount = getPending().length;
render();

process.stdin.on("data", (key: string) => {
  if (mode !== "list") return;

  const pending = getPending();

  // Ctrl+C / q — quit
  if (key === "\x03" || key === "q") {
    process.stdout.write("\x1b[2J\x1b[H");
    process.exit(0);
  }

  // j / down arrow — next
  if (key === "j" || key === "\x1b[B") {
    if (pending.length > 0) {
      cursor = Math.min(cursor + 1, pending.length - 1);
      render();
    }
    return;
  }

  // k / up arrow — previous
  if (key === "k" || key === "\x1b[A") {
    cursor = Math.max(cursor - 1, 0);
    render();
    return;
  }

  // g — go to top
  if (key === "g") {
    cursor = 0;
    render();
    return;
  }

  // G — go to bottom
  if (key === "G") {
    if (pending.length > 0) cursor = pending.length - 1;
    render();
    return;
  }

  // Enter — respond to selected
  if (key === "\r" || key === "\n") {
    if (pending.length > 0 && pending[cursor]) {
      respondToItem(pending[cursor]);
    }
    return;
  }

  // d — dismiss selected
  if (key === "d") {
    if (pending.length > 0 && pending[cursor]) {
      dismissItem(pending[cursor]);
    }
    return;
  }

  // h — toggle history
  if (key === "h") {
    showHistory = !showHistory;
    render();
    return;
  }

  // r — refresh
  if (key === "r") {
    items = loadQueue();
    cursor = Math.min(cursor, Math.max(0, getPending().length - 1));
    render();
    return;
  }

  // 1-9 — jump to item and respond
  const num = parseInt(key);
  if (!isNaN(num) && num >= 1 && num <= pending.length) {
    cursor = num - 1;
    render();
    // Small delay so user sees the selection before response prompt
    setTimeout(() => respondToItem(pending[cursor]), 150);
    return;
  }
});
