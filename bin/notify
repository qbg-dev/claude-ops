#!/usr/bin/env bash
# notify — Publish a notification event to the event bus (side-effect shows macOS alert).
# Also calls terminal-notifier directly as fallback for sessions without a project bus.
# Usage: notify "message"
#        notify "message" "Custom Title"
#        notify "message" "Custom Title" "https://example.com"
#        notify "message" "" "https://example.com"        # default title + URL
#        notify "message" "" "/path/to/file.html"         # local file (auto file:// prefix)

# Parse --no-triage flag before positional args
_NO_TRIAGE=0
_ARGS=()
for _a in "$@"; do
  if [ "$_a" = "--no-triage" ]; then _NO_TRIAGE=1
  else _ARGS+=("$_a"); fi
done
set -- "${_ARGS[@]}"

msg="${1:?Usage: notify \"message\" [\"title\"] [\"url\"] [--no-triage]}"
title="${2:-🔔 Claude}"
url="${3:-}"

# ── Find PROJECT_ROOT ────────────────────────────────────────────────────────
_PROJECT_ROOT="${PROJECT_ROOT:-}"
if [ -z "$_PROJECT_ROOT" ] && command -v git >/dev/null 2>&1; then
  _PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
fi
[ -z "$_PROJECT_ROOT" ] && _PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# ── Append to triage queue (.claude/triage/queue.jsonl) ──────────────────────
_TRIAGE_DIR="$_PROJECT_ROOT/.claude/triage"
if [ "$_NO_TRIAGE" -eq 0 ] && [ -n "$_PROJECT_ROOT" ] && [ -d "$_PROJECT_ROOT/.claude" ]; then
  mkdir -p "$_TRIAGE_DIR" 2>/dev/null || true

  # Auto-detect calling worker from WORKER_NAME env or registry pane_id lookup
  _FROM_WORKER="${WORKER_NAME:-}"
  if [ -z "$_FROM_WORKER" ] && [ -n "${TMUX_PANE:-}" ]; then
    _REG="$_PROJECT_ROOT/.claude/workers/registry.json"
    if [ -f "$_REG" ]; then
      _FROM_WORKER=$(jq -r --arg pid "$TMUX_PANE" '
        to_entries[] | select(.key != "_config") | select(.value.pane_id == $pid) | .key
      ' "$_REG" 2>/dev/null | head -1 || true)
    fi
  fi

  _TQ_ID="tq-$(date +%s)$(printf '%04d' $$)"
  _TQ_ENTRY=$(jq -nc \
    --arg id "$_TQ_ID" \
    --arg title "$msg" \
    --arg source "${_FROM_WORKER:-notify}" \
    --arg from "${_FROM_WORKER:-}" \
    --arg now "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{id:$id, category:"notification", title:$title, detail:$title,
      source:$source, from_worker:(if $from == "" then null else $from end),
      added_at:$now, status:"pending"}' 2>/dev/null || true)
  [ -n "$_TQ_ENTRY" ] && printf '%s\n' "$_TQ_ENTRY" >> "$_TRIAGE_DIR/queue.jsonl"
fi

# ── Publish to event bus (side-effect fires notify_human_agent.sh) ──────────────

BUS_STREAM="$_PROJECT_ROOT/.claude/bus/stream.jsonl"
if [ -f "$BUS_STREAM" ] || [ -d "$(dirname "$BUS_STREAM")" ]; then
  EVENT_BUS_LIB="$HOME/.claude-ops/lib/event-bus.sh"
  if [ -f "$EVENT_BUS_LIB" ]; then
    # shellcheck source=/dev/null
    source "$EVENT_BUS_LIB" 2>/dev/null
    PAYLOAD=$(jq -nc \
      --arg message "$msg" \
      --arg title "$title" \
      --arg url "$url" \
      '{"message":$message,"title":$title,"url":(if $url == "" then null else $url end)}' 2>/dev/null || true)
    [ -n "$PAYLOAD" ] && bus_publish "notification" "$PAYLOAD" 2>/dev/null || true
  fi
fi

# ── Direct macOS notification (fallback — always fires) ───────────────────
click_args=()
if [ -n "$url" ]; then
  [[ "$url" == /* ]] && url="file://$url"
  click_args+=(-open "$url")
elif [ -n "$TMUX" ] && [ -n "$TMUX_PANE" ]; then
  socket="$(echo "$TMUX" | cut -d, -f1)"
  tmux_bin="/opt/homebrew/bin/tmux"
  exec_cmd="$tmux_bin -S $socket select-window -t $TMUX_PANE && $tmux_bin -S $socket select-pane -t $TMUX_PANE && $tmux_bin -S $socket resize-pane -Z -t $TMUX_PANE"
  click_args+=(-execute "$exec_cmd")
fi

terminal-notifier -title "$title" -message "$msg" -sound default "${click_args[@]}"
